<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://android.com"
    xmlns:tools="http://android.com"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:padding="24dp">

    <!-- En-tête de l'application -->
    <LinearLayout
        android:id="@+id/headerArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentTop="true"
        android:gravity="center"
        android:layout_marginTop="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RED TEAM PROXY"
            android:textColor="#00FF66"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STATION DE PIVOTEMENT MOBILE"
            android:textColor="#8B949E"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Zone Centrale : Statut et Bouton -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_centerInParent="true">

        <!-- Indicateur d'état -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STATUS: STANDBY"
            android:textColor="#FF3333"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:background="#1F1515"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:layout_marginBottom="40dp"/>

        <!-- Bouton d'action principal -->
        <Button
            android:id="@+id/btnToggleProxy"
            android:layout_width="200dp"
            android:layout_height="60dp"
            android:text="INITIALISER"
            android:textColor="#0D1117"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:backgroundTint="#00FF66"
            android:elevation="4dp"/>
    </LinearLayout>

    <!-- Pied de page avec Copyright personnalisé -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ENGINE v2.0 - ENCRYPTED SOCKS5"
            android:textColor="#484F58"
            android:textSize="11sp"
            android:fontFamily="monospace" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="© 2026 hacker_one225 😈"
            android:textColor="#00FF66"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginTop="4dp"
            android:alpha="0.8"/>
    </LinearLayout>

</RelativeLayout>
          
